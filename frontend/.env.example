# LeadForge Frontend Environment Variables
# Copy this file to .env or set these in your deployment dashboard (e.g., Vercel)

# The Backend API URL (e.g., https://your-backend.onrender.com)
# In production on Vercel, if this is NOT set, the app will fallback to "/api" 
# which is then proxied via vercel.json rewrites.
VITE_API_BASE_URL=
